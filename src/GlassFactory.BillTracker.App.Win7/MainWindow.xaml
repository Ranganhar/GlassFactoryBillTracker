<Window x:Class="GlassFactory.BillTracker.App.Win7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BillTracker Win7"
        Width="1280"
        Height="780"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">
        <ToolBar DockPanel.Dock="Top">
            <Button Content="新增客户" Width="90" Margin="2" Click="AddCustomer_Click" />
            <Button Content="编辑客户" Width="90" Margin="2" Click="EditCustomer_Click" />
            <Button Content="删除客户" Width="90" Margin="2" Click="DeleteCustomer_Click" />
            <Separator />
            <Button Content="新增订单" Width="90" Margin="2" Click="AddOrder_Click" />
            <Button Content="编辑订单" Width="90" Margin="2" Click="EditOrder_Click" />
            <Button Content="删除订单" Width="90" Margin="2" Click="DeleteOrder_Click" />
            <Separator />
            <Button Content="导出 Excel" Width="100" Margin="2" Click="ExportExcel_Click" />
            <Button Content="导出 JSON" Width="100" Margin="2" Click="ExportJson_Click" />
            <Button Content="打印所选" Width="100" Margin="2" Click="PrintSelected_Click" />
            <Separator />
            <TextBlock VerticalAlignment="Center" Text="关键词" Margin="6,0,4,0" />
            <TextBox x:Name="KeywordTextBox" Width="200" />
            <Button Content="查询" Width="70" Margin="6,0,0,0" Click="Search_Click" />
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="客户列表" Padding="8">
                <DataGrid x:Name="CustomersGrid"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          SelectionChanged="CustomersGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120" />
                        <DataGridTextColumn Header="电话" Binding="{Binding Phone}" Width="100" />
                        <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="订单列表" Padding="8">
                <DataGrid x:Name="OrdersGrid"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" Width="150" />
                        <DataGridTextColumn Header="日期" Binding="{Binding DateTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="170" />
                        <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="120" />
                        <DataGridTextColumn Header="支付方式" Binding="{Binding PaymentMethod}" Width="90" />
                        <DataGridTextColumn Header="订单状态" Binding="{Binding OrderStatus}" Width="90" />
                        <DataGridTextColumn Header="总金额" Binding="{Binding TotalAmount, StringFormat=F2}" Width="100" />
                        <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
