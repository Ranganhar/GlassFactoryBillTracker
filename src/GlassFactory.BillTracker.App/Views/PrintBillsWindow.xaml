<Window x:Class="GlassFactory.BillTracker.App.Views.PrintBillsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="打印账单"
        Width="760"
        Height="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="抬头" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox x:Name="HeaderTextBox" Grid.Column="1" Text="亿达夹丝玻璃" />
            <TextBlock Grid.Column="2" Text="模板" VerticalAlignment="Center" Margin="12,0,6,0" />
            <ComboBox x:Name="TemplateComboBox" Grid.Column="3" SelectionChanged="TemplateComboBox_SelectionChanged">
                <ComboBoxItem Content="点阵联打" Tag="DotMatrix" IsSelected="True" />
                <ComboBoxItem Content="A4 模板" Tag="A4" />
            </ComboBox>
            <TextBlock Grid.Column="4" Text="联打高度" VerticalAlignment="Center" Margin="12,0,6,0" />
            <ComboBox x:Name="DotMatrixHeightComboBox" Grid.Column="5">
                <ComboBoxItem Content="整张 280mm (1联)" Tag="Full" />
                <ComboBoxItem Content="半张 140mm (2联)" Tag="Half" />
                <ComboBoxItem Content="三分之一 93mm (3联)" Tag="Third" IsSelected="True" />
            </ComboBox>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="UseCustomerPhoneCheckBox" Grid.Column="0" Content="使用客户电话" IsChecked="True" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="自定义电话" VerticalAlignment="Center" Margin="12,0,6,0" />
            <TextBox x:Name="CustomPhoneTextBox" Grid.Column="2" />
            <Button Grid.Column="4" Content="选择打印机" Width="120" Margin="10,0,0,0" Click="SelectPrinterButton_Click" />
        </Grid>

        <GroupBox Grid.Row="2" Header="已选订单" Margin="0,0,0,8">
            <ListBox x:Name="OrdersListBox" DisplayMemberPath="OrderNo" />
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="PrinterTextBlock" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="Gray" />
            <Button Content="打印" Width="100" Margin="0,0,8,0" Click="PrintButton_Click" />
            <Button Content="取消" Width="100" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
