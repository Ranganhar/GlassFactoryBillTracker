<Window x:Class="GlassFactory.BillTracker.App.Views.PrintBillsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:GlassFactory.BillTracker.App.Models"
        Title="打印账单"
        Width="1100"
        Height="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="抬头" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Grid.Column="1" Text="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="2" Text="模板" VerticalAlignment="Center" Margin="12,0,6,0" />
            <ComboBox Grid.Column="3" SelectedValuePath="Tag" SelectedValue="{Binding SelectedTemplate, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="点阵联打" Tag="{x:Static models:PrintTemplateKind.DotMatrix}" />
                <ComboBoxItem Content="A4 模板" Tag="{x:Static models:PrintTemplateKind.A4}" />
            </ComboBox>
            <TextBlock Grid.Column="4" Text="联打高度" VerticalAlignment="Center" Margin="12,0,6,0" />
            <TextBlock Grid.Column="5" Text="93mm（单联）" VerticalAlignment="Center" />
            <TextBlock Grid.Column="6" Text="字号" VerticalAlignment="Center" Margin="12,0,6,0" />
            <ComboBox Grid.Column="7" ItemsSource="{Binding FontSizes}" SelectedItem="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="使用客户电话" IsChecked="{Binding UseCustomerPhone}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="自定义电话" VerticalAlignment="Center" Margin="12,0,6,0" />
            <TextBox Grid.Column="2" Text="{Binding CustomPhone, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Column="3" Text="Padding" VerticalAlignment="Center" Margin="12,0,6,0" />
            <ComboBox Grid.Column="4" ItemsSource="{Binding CellPaddingOptions}" SelectedItem="{Binding CellPaddingDip, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="6" Content="选择打印机" Width="120" Margin="10,0,0,0" Click="SelectPrinterButton_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="打印预览" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Grid.Column="1" x:Name="PrinterTextBlock" VerticalAlignment="Center" Foreground="Gray" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="已选订单">
                <ListBox DisplayMemberPath="OrderNo" ItemsSource="{Binding Orders}" />
            </GroupBox>

            <GroupBox Grid.Column="2" Header="文档预览">
                <DocumentViewer Document="{Binding PreviewDocument}" />
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="打印" Width="100" Margin="0,0,8,0" Click="PrintButton_Click" />
            <Button Content="取消" Width="100" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
