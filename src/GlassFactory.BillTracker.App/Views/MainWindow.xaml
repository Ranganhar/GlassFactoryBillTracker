<Window x:Class="GlassFactory.BillTracker.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:GlassFactory.BillTracker.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="夹丝玻璃加工厂订单管理系统"
        Width="1280"
        Height="800"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewOrderCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteOrderCommand}" />
        <KeyBinding Key="F" Modifiers="Control" Command="Find" />
        <KeyBinding Key="L" Modifiers="Control" Command="{x:Static local:MainWindow.FocusLeftCommand}" />
        <KeyBinding Key="Escape" Command="{x:Static local:MainWindow.ClearOrderSearchCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="Find" Executed="FindCommand_Executed" />
        <CommandBinding Command="{x:Static local:MainWindow.FocusLeftCommand}" Executed="FocusLeftCommand_Executed" />
        <CommandBinding Command="{x:Static local:MainWindow.ClearOrderSearchCommand}" Executed="ClearOrderSearchCommand_Executed" />
    </Window.CommandBindings>
    <DockPanel Margin="10">
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="新建订单(Ctrl+N)" Command="{Binding NewOrderCommand}" Margin="2" />
                <Button Content="编辑订单" Command="{Binding EditOrderCommand}" Margin="2" />
                <Button Content="删除订单(Del)" Command="{Binding DeleteOrderCommand}" Margin="2" />
                <Separator />
                <Button Content="导出Excel" Command="{Binding ExportExcelCommand}" Margin="2" />
                <Button Content="导出JSON" Command="{Binding ExportJsonCommand}" Margin="2" />
                <Button Content="全选当前结果" Command="{Binding SelectAllOrdersCommand}" Margin="2" />
                <Button Content="清空勾选" Command="{Binding ClearOrderSelectionCommand}" Margin="2" />
                <Button Content="导出选中" Command="{Binding ExportSelectedCommand}" Margin="2" />
                <Button Content="打印选中" Command="{Binding PrintSelectedCommand}" Margin="2" />
                <Button Content="Delete Selected (删除选中订单)" Command="{Binding DeleteSelectedOrdersCommand}" Margin="2" />
                <Button Content="刷新" Command="{Binding RefreshCommand}" Margin="2" />
                <Separator />
                <TextBlock VerticalAlignment="Center" Margin="4,0,4,0" Text="已选：" />
                <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding SelectedOrderCount}" />
                <Separator />
                <TextBlock VerticalAlignment="Center" Margin="8,0,4,0" Text="搜索：" />
                <TextBox x:Name="OrderSearchBox"
                         Width="220"
                         VerticalAlignment="Center"
                         KeyDown="OrderSearchBox_KeyDown"
                         Text="{Binding OrderSearchKeyword, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="查询" Command="{Binding SearchCommand}" Margin="6,0,0,0" />
            </ToolBar>
        </ToolBarTray>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Text="客户列表" Margin="0,0,0,8" />

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="CustomerSearchBox"
                                     Width="170"
                                     Text="{Binding CustomerSearchKeyword, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="搜索" Command="{Binding SearchCustomersCommand}" Margin="6,0,0,0" />
                        </StackPanel>
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="新增" Command="{Binding AddCustomerCommand}" Margin="0,0,6,0" />
                            <Button Content="编辑" Command="{Binding EditCustomerCommand}" Margin="0,0,6,0" />
                            <Button Content="删除" Command="{Binding DeleteCustomerCommand}" />
                        </WrapPanel>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <ListBox ItemsSource="{Binding Customers}"
                                 SelectedItem="{Binding SelectedCustomer}"
                                 DisplayMemberPath="Name" />
                        <TextBlock Text="暂无客户，请先新增客户"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   Visibility="{Binding IsCustomerEmpty, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#EEE" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="开始日期" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <DatePicker Grid.Column="1" SelectedDate="{Binding StartDate}" />

                            <TextBlock Grid.Column="2" Text="结束日期" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <DatePicker Grid.Column="3" SelectedDate="{Binding EndDate}" />

                            <TextBlock Grid.Column="4" Text="最小金额" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <TextBox Grid.Column="5" Text="{Binding MinAmountText}" />

                            <TextBlock Grid.Column="6" Text="最大金额" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <TextBox Grid.Column="7" Text="{Binding MaxAmountText}" />

                            <ComboBox Grid.Column="9"
                                      Margin="12,0,0,0"
                                      ItemsSource="{Binding PaymentMethodFilters}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedPaymentFilter}" />

                            <ComboBox Grid.Column="11"
                                      Margin="12,0,0,0"
                                      ItemsSource="{Binding OrderStatusFilters}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding SelectedStatusFilter}" />

                            <StackPanel Grid.Column="12" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="应用筛选" Command="{Binding SearchCommand}" Margin="8,0,0,0" />
                                <Button Content="清除筛选" Command="{Binding ClearFiltersCommand}" Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DockPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding ResultSummaryText}" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FilterChips}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="10" Margin="0,0,6,4" Padding="8,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" Margin="0,0,6,0" />
                                                <Button Content="×"
                                                        Width="18"
                                                        Height="18"
                                                        Padding="0"
                                                        Command="{Binding DataContext.RemoveChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Key}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <DataGrid x:Name="OrdersDataGrid"
                                  ItemsSource="{Binding Orders}"
                                  SelectedItem="{Binding SelectedOrder}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserSortColumns="True"
                                  Sorting="OrdersDataGrid_Sorting"
                                  MouseDoubleClick="OrdersDataGrid_MouseDoubleClick"
                                  SelectionUnit="FullRow"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="选择" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" SortMemberPath="OrderNo" Width="150" IsReadOnly="True" />
                                <DataGridTextColumn Header="日期时间" Binding="{Binding DateTime, StringFormat=yyyy-MM-dd HH:mm:ss}" SortMemberPath="DateTime" Width="170" IsReadOnly="True" />
                                <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" SortMemberPath="CustomerName" Width="120" IsReadOnly="True" />
                                <DataGridTextColumn Header="支付方式" Binding="{Binding PaymentMethod}" SortMemberPath="PaymentMethod" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="订单状态" Binding="{Binding OrderStatus}" SortMemberPath="OrderStatus" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="总金额" Binding="{Binding TotalAmount, StringFormat=F4}" SortMemberPath="TotalAmount" Width="120" IsReadOnly="True" />
                                <DataGridTextColumn Header="备注" Binding="{Binding Note}" SortMemberPath="Note" Width="*" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="暂无订单数据"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Gray"
                                   Visibility="{Binding IsOrderEmpty, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
