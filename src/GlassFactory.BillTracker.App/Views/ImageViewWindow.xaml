<Window x:Class="GlassFactory.BillTracker.App.Views.ImageViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图片预览"
        Width="960"
        Height="700"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ImagePathText"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Zoom -" Width="72" Margin="0,0,6,0" Click="ZoomOutButton_Click" />
                    <Button Content="Zoom +" Width="72" Margin="0,0,6,0" Click="ZoomInButton_Click" />
                    <Button Content="Fit" Width="60" Margin="0,0,6,0" Click="FitButton_Click" />
                    <Button Content="100%" Width="60" Margin="0,0,6,0" Click="ResetZoomButton_Click" />
                    <TextBlock x:Name="ZoomPercentText"
                               Width="56"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="ImageScrollViewer"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="False"
                      PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel"
                      SizeChanged="ImageScrollViewer_SizeChanged">
            <Image x:Name="PreviewImage"
                   Stretch="None"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   RenderTransformOrigin="0,0">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="PreviewScaleTransform" ScaleX="1" ScaleY="1" />
                </Image.RenderTransform>
            </Image>
        </ScrollViewer>
    </Grid>
</Window>
