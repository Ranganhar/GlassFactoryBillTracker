<Window x:Class="GlassFactory.BillTracker.App.Views.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GlassFactory.BillTracker.App.Converters"
        Title="订单编辑"
        Width="1300"
        Height="760"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
    </Window.Resources>
    <DockPanel Margin="10">
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="订单号" />
                <TextBox Grid.Row="0" Grid.Column="1" IsReadOnly="True" Text="{Binding OrderNo}" Margin="0,0,10,6" />

                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="日期" />
                <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding SelectedDate}" Margin="0,0,10,6" />

                <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="时间" />
                <StackPanel Grid.Row="0" Grid.Column="5" Orientation="Horizontal" Margin="0,0,0,6">
                    <ComboBox Width="80" ItemsSource="{Binding Hours}" SelectedItem="{Binding SelectedHour}" />
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0" />
                    <ComboBox Width="80" ItemsSource="{Binding Minutes}" SelectedItem="{Binding SelectedMinute}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="客户*" />
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,6">
                    <TextBox Text="{Binding CustomerPickerKeyword, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="输入客户名或拼音首字母过滤"
                             Margin="0,0,0,4" />
                    <ComboBox x:Name="CustomerComboBox"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding FilteredCustomers}"
                              SelectedItem="{Binding SelectedCustomer}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="支付方式" />
                <ComboBox Grid.Row="1" Grid.Column="3"
                          ItemsSource="{Binding PaymentMethods}"
                          SelectedItem="{Binding SelectedPaymentMethod}"
                          Margin="0,0,10,6" />

                <TextBlock Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Text="订单状态" />
                <ComboBox Grid.Row="1" Grid.Column="5"
                          ItemsSource="{Binding OrderStatuses}"
                          SelectedItem="{Binding SelectedOrderStatus}"
                          Margin="0,0,0,6" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" Text="备注" />
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5"
                         AcceptsReturn="True"
                         Height="60"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <Button Content="添加照片" Command="{Binding ChooseAttachmentCommand}" Width="120" Margin="0,0,0,6" />
                    <Button Content="移除选中照片" Command="{Binding RemoveAttachmentCommand}" Width="120" />
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontWeight="Bold" Text="附件照片（可多选，双击缩略图查看）" Margin="0,0,0,6" />

                    <ListBox x:Name="AttachmentListBox"
                             Grid.Row="1"
                             ItemsSource="{Binding Attachments}"
                             SelectedItem="{Binding SelectedAttachment}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             MouseDoubleClick="AttachmentListBox_MouseDoubleClick">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="110" Margin="0,0,8,6">
                                    <Border BorderBrush="#CCC" BorderThickness="1" Padding="2">
                                        <Image Width="100"
                                               Height="72"
                                               Stretch="UniformToFill"
                                               Source="{Binding AbsolutePath, Converter={StaticResource PathToImageSourceConverter}}" />
                                    </Border>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="ItemsDataGrid" Grid.Row="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Resources>
                    <Style x:Key="RightAlignedDisplayCellStyle" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Right" />
                        <Setter Property="TextAlignment" Value="Right" />
                    </Style>
                    <Style x:Key="RightAlignedEditingStyle" TargetType="TextBox">
                        <Setter Property="HorizontalContentAlignment" Value="Right" />
                        <Setter Property="TextAlignment" Value="Right" />
                    </Style>
                    <Style x:Key="ModelEditingStyle" TargetType="TextBox">
                        <Setter Property="MaxLength" Value="13" />
                    </Style>
                    <Style x:Key="IntegerEditingStyle" TargetType="TextBox" BasedOn="{StaticResource RightAlignedEditingStyle}">
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="型号" Binding="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Width="90" MinWidth="80" MaxWidth="95" EditingElementStyle="{StaticResource ModelEditingStyle}" />
                    <DataGridTemplateColumn Header="样块型号" Width="120" MinWidth="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox IsEditable="True"
                                          Text="{Binding SampleBlockModel, UpdateSourceTrigger=LostFocus}"
                                          ItemsSource="{Binding DataContext.SampleBlockModels, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="丝" Binding="{Binding WireType}" IsReadOnly="True" Width="100" MinWidth="80" />
                    <DataGridTextColumn Header="价格(参考)" Binding="{Binding WireUnitPrice, StringFormat=F0}" IsReadOnly="True" Width="80" MinWidth="70" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" />
                    <DataGridTextColumn Header="长(mm)" Binding="{Binding GlassLengthMm, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="70" MinWidth="65" MaxWidth="75" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="宽(mm)" Binding="{Binding GlassWidthMm, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="70" MinWidth="65" MaxWidth="75" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="62" MinWidth="58" MaxWidth="66" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="平方(㎡)" Binding="{Binding AreaM2, StringFormat=F2}" IsReadOnly="True" Width="70" MinWidth="66" MaxWidth="80" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" />
                    <DataGridTextColumn Header="单价(元/㎡)" Binding="{Binding GlassUnitPricePerM2, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="78" MinWidth="74" MaxWidth="84" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="打孔费" Binding="{Binding HoleFee, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}" Width="68" MinWidth="64" MaxWidth="72" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="其他费用" Binding="{Binding OtherFee, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="68" MinWidth="64" MaxWidth="72" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="金额(元)" Binding="{Binding Amount, StringFormat=F0}" IsReadOnly="True" Width="90" MinWidth="86" MaxWidth="95" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="*" MinWidth="360" />
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1" Margin="0,10,0,6">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="总计" FontWeight="Bold" FontSize="15" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding TotalQuantity, StringFormat=总数量：{0}}" FontSize="15" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding TotalAreaM2, StringFormat=总方数：{0:F2}}" FontSize="15" />
                </StackPanel>
                <TextBlock Text="{Binding TotalAmount, StringFormat=合计：{0:F0}}"
                           HorizontalAlignment="Right"
                           FontWeight="Bold"
                           FontSize="15" />
            </Grid>

            <DockPanel Grid.Row="2" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="新增明细行" Command="{Binding AddItemCommand}" Width="110" Margin="0,0,8,0" />
                    <Button Content="复制行" Command="{Binding CopySelectedItemCommand}" Width="90" Margin="0,0,8,0" />
                    <Button Content="删除选中行" Command="{Binding RemoveSelectedItemCommand}" Width="110" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="保存" Width="110" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                    <Button Content="取消" Width="90" Command="{Binding CancelCommand}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
