<Window x:Class="GlassFactory.BillTracker.App.Views.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GlassFactory.BillTracker.App.Converters"
        Title="订单编辑"
        Width="1100"
        Height="760"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
    </Window.InputBindings>

    <DockPanel Margin="10">
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="订单号" />
                <TextBox Grid.Row="0" Grid.Column="1" IsReadOnly="True" Text="{Binding OrderNo}" Margin="0,0,10,6" />

                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="日期" />
                <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding SelectedDate}" Margin="0,0,10,6" />

                <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="时间" />
                <StackPanel Grid.Row="0" Grid.Column="5" Orientation="Horizontal" Margin="0,0,0,6">
                    <ComboBox Width="80" ItemsSource="{Binding Hours}" SelectedItem="{Binding SelectedHour}" />
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0" />
                    <ComboBox Width="80" ItemsSource="{Binding Minutes}" SelectedItem="{Binding SelectedMinute}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="客户*" />
                <ComboBox x:Name="CustomerComboBox" Grid.Row="1" Grid.Column="1"
                          DisplayMemberPath="Name"
                          ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          Margin="0,0,10,6" />

                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="支付方式" />
                <ComboBox Grid.Row="1" Grid.Column="3"
                          ItemsSource="{Binding PaymentMethods}"
                          SelectedItem="{Binding SelectedPaymentMethod}"
                          Margin="0,0,10,6" />

                <TextBlock Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Text="订单状态" />
                <ComboBox Grid.Row="1" Grid.Column="5"
                          ItemsSource="{Binding OrderStatuses}"
                          SelectedItem="{Binding SelectedOrderStatus}"
                          Margin="0,0,0,6" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" Text="备注" />
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5"
                         AcceptsReturn="True"
                         Height="60"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Width="130"
                       Height="90"
                       Stretch="UniformToFill"
                       Source="{Binding AttachmentPreviewAbsolutePath, Converter={StaticResource PathToImageSourceConverter}}" />

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Button Content="选择图片" Command="{Binding ChooseAttachmentCommand}" Width="120" Margin="0,0,0,6" />
                    <Button Content="移除附件" Command="{Binding RemoveAttachmentCommand}" Width="120" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontWeight="Bold" Text="附件（单张）" />
                    <TextBlock Text="{Binding AttachmentDisplayName}" Foreground="Gray" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="ItemsDataGrid" Grid.Row="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="型号" Binding="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                    <DataGridTextColumn Header="长(mm)" Binding="{Binding GlassLengthMm, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                    <DataGridTextColumn Header="宽(mm)" Binding="{Binding GlassWidthMm, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                    <DataGridTextColumn Header="玻璃单价(元/㎡)" Binding="{Binding GlassUnitPricePerM2, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                    <DataGridTextColumn Header="打孔费" Binding="{Binding HoleFee, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                    <DataGridTextColumn Header="其他费用" Binding="{Binding OtherFee, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                    <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat=F4}" IsReadOnly="True" Width="110" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="新增明细行" Command="{Binding AddItemCommand}" Width="110" Margin="0,0,8,0" />
                    <Button Content="删除选中行" Command="{Binding RemoveSelectedItemCommand}" Width="110" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <TextBlock Text="总金额：" VerticalAlignment="Center" FontWeight="Bold" />
                    <TextBox Width="130" IsReadOnly="True" Text="{Binding TotalAmount, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F4}" Margin="4,0,12,0" />
                    <Button Content="保存(Ctrl+S)" Width="110" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                    <Button Content="取消" Width="90" Command="{Binding CancelCommand}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
