<Window x:Class="GlassFactory.BillTracker.App.Views.OrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GlassFactory.BillTracker.App.Converters"
        Title="订单编辑"
        Width="1100"
        Height="760"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />
    </Window.Resources>
    <DockPanel Margin="10">
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="订单号" />
                <TextBox Grid.Row="0" Grid.Column="1" IsReadOnly="True" Text="{Binding OrderNo}" Margin="0,0,10,6" />

                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="日期" />
                <DatePicker Grid.Row="0" Grid.Column="3" SelectedDate="{Binding SelectedDate}" Margin="0,0,10,6" />

                <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="时间" />
                <StackPanel Grid.Row="0" Grid.Column="5" Orientation="Horizontal" Margin="0,0,0,6">
                    <ComboBox Width="80" ItemsSource="{Binding Hours}" SelectedItem="{Binding SelectedHour}" />
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0" />
                    <ComboBox Width="80" ItemsSource="{Binding Minutes}" SelectedItem="{Binding SelectedMinute}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="客户*" />
                <ComboBox x:Name="CustomerComboBox" Grid.Row="1" Grid.Column="1"
                          DisplayMemberPath="Name"
                          ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          Margin="0,0,10,6" />

                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="支付方式" />
                <ComboBox Grid.Row="1" Grid.Column="3"
                          ItemsSource="{Binding PaymentMethods}"
                          SelectedItem="{Binding SelectedPaymentMethod}"
                          Margin="0,0,10,6" />

                <TextBlock Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Text="订单状态" />
                <ComboBox Grid.Row="1" Grid.Column="5"
                          ItemsSource="{Binding OrderStatuses}"
                          SelectedItem="{Binding SelectedOrderStatus}"
                          Margin="0,0,0,6" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Top" Text="备注" />
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="5"
                         AcceptsReturn="True"
                         Height="60"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Width="130"
                       Height="90"
                       Stretch="UniformToFill"
                       Source="{Binding AttachmentPreviewAbsolutePath, Converter={StaticResource PathToImageSourceConverter}}" />

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Button Content="选择图片" Command="{Binding ChooseAttachmentCommand}" Width="120" Margin="0,0,0,6" />
                    <Button Content="移除附件" Command="{Binding RemoveAttachmentCommand}" Width="120" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontWeight="Bold" Text="附件（单张）" />
                    <TextBlock Text="{Binding AttachmentDisplayName}" Foreground="Gray" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="ItemsDataGrid" Grid.Row="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      PreviewMouseRightButtonDown="ItemsDataGrid_OnPreviewMouseRightButtonDown"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Resources>
                    <Style x:Key="RightAlignedDisplayCellStyle" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Right" />
                        <Setter Property="TextAlignment" Value="Right" />
                    </Style>
                    <Style x:Key="RightAlignedEditingStyle" TargetType="TextBox">
                        <Setter Property="HorizontalContentAlignment" Value="Right" />
                        <Setter Property="TextAlignment" Value="Right" />
                    </Style>
                    <Style x:Key="ModelEditingStyle" TargetType="TextBox">
                        <Setter Property="MaxLength" Value="13" />
                    </Style>
                    <Style x:Key="IntegerEditingStyle" TargetType="TextBox" BasedOn="{StaticResource RightAlignedEditingStyle}">
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="型号" Binding="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Width="90" MinWidth="80" MaxWidth="95" EditingElementStyle="{StaticResource ModelEditingStyle}" />
                    <DataGridTextColumn Header="长(mm)" Binding="{Binding GlassLengthMm, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="70" MinWidth="65" MaxWidth="75" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="宽(mm)" Binding="{Binding GlassWidthMm, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="70" MinWidth="65" MaxWidth="75" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="数量" Binding="{Binding Quantity, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="62" MinWidth="58" MaxWidth="66" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="玻璃单价" Binding="{Binding GlassUnitPricePerM2, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="78" MinWidth="74" MaxWidth="84" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="打孔费" Binding="{Binding HoleFee, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="68" MinWidth="64" MaxWidth="72" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="其他费用" Binding="{Binding OtherFee, UpdateSourceTrigger=LostFocus, StringFormat=F0}" Width="68" MinWidth="64" MaxWidth="72" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" EditingElementStyle="{StaticResource IntegerEditingStyle}" />
                    <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat=F2}" IsReadOnly="True" Width="90" MinWidth="86" MaxWidth="95" ElementStyle="{StaticResource RightAlignedDisplayCellStyle}" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" Width="*" MinWidth="360" />
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1" Margin="0,10,0,6">
                <TextBlock Text="{Binding TotalAmount, StringFormat=合计：{0:F2}}"
                           HorizontalAlignment="Right"
                           FontWeight="Bold"
                           FontSize="15" />
            </Grid>

            <DockPanel Grid.Row="2" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="新增明细行" Command="{Binding AddItemCommand}" Width="110" Margin="0,0,8,0" />
                    <Button Content="复制行" Command="{Binding CopySelectedItemCommand}" Width="90" Margin="0,0,8,0" />
                    <Button Content="删除选中行" Command="{Binding RemoveSelectedItemCommand}" Width="110" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="保存" Width="110" Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                    <Button Content="取消" Width="90" Command="{Binding CancelCommand}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
